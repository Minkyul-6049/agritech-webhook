    {
        "id": "5f5b53b8945571f5",
        "type": "ui_template",
        "z": "a9ae75c3b16829df",
        "group": "c4fede1c9a4bfbeb",
        "name": "",
        "order": 0,
        "width": "12",
        "height": "15",
        "format": "<div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; height: 100%; min-height: 300px; padding: 10px; background-color: white; border: 1px solid #333; text-align: center; font-family: sans-serif;\">\n    \n    <!-- Zone 1 -->\n    <div style=\"background-color: {{msg.payload.c1 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 1<br><span style=\"font-size: 1.5em;\">{{msg.payload.v1 || '--'}}</span>\n    </div>\n    <!-- Zone 2 -->\n    <div style=\"background-color: {{msg.payload.c2 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 2<br><span style=\"font-size: 1.5em;\">{{msg.payload.v2 || '--'}}</span>\n    </div>\n    <!-- Zone 3 -->\n    <div style=\"background-color: {{msg.payload.c3 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 3<br><span style=\"font-size: 1.5em;\">{{msg.payload.v3 || '--'}}</span>\n    </div>\n    \n    <!-- Zone 4 -->\n    <div style=\"background-color: {{msg.payload.c4 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 4<br><span style=\"font-size: 1.5em;\">{{msg.payload.v4 || '--'}}</span>\n    </div>\n    <!-- Zone 5 -->\n    <div style=\"background-color: {{msg.payload.c5 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 5<br><span style=\"font-size: 1.5em;\">{{msg.payload.v5 || '--'}}</span>\n    </div>\n    <!-- Zone 6 -->\n    <div style=\"background-color: {{msg.payload.c6 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 6<br><span style=\"font-size: 1.5em;\">{{msg.payload.v6 || '--'}}</span>\n    </div>\n    \n    <!-- Zone 7 -->\n    <div style=\"background-color: {{msg.payload.c7 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 7<br><span style=\"font-size: 1.5em;\">{{msg.payload.v7 || '--'}}</span>\n    </div>\n    <!-- Zone 8 -->\n    <div style=\"background-color: {{msg.payload.c8 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 8<br><span style=\"font-size: 1.5em;\">{{msg.payload.v8 || '--'}}</span>\n    </div>\n    <!-- Zone 9 -->\n    <div style=\"background-color: {{msg.payload.c9 || '#0099cc'}}; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-weight: bold; border-radius: 5px;\">\n        Zone 9<br><span style=\"font-size: 1.5em;\">{{msg.payload.v9 || '--'}}</span>\n    </div>\n</div>",
