    {
        "id": "da42f62131848855",
        "type": "function",
        "z": "a9ae75c3b16829df",
        "name": "Parse Prom JSON",
        "func": "// Extract the actual value from Prometheus JSON response\n// Prometheus 'up' query returns \"1\" (success) or \"0\" (fail)\nlet serverState = msg.payload.data.result[0].value[1];\n\n// Convert the raw value to a readable status\nlet statusMsg = (serverState === \"1\") ? \"🟢 Server UP\" : \"🔴 Server DOWN\";\n\n// Rebuild the payload for output\nmsg.payload = {\n    status: statusMsg,\n    rawData: serverState\n};\n\nreturn msg;",
