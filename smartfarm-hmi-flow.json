    {
        "id": "85adb5928ae7fa65",
        "type": "function",
        "z": "a9ae75c3b16829df",
        "name": "Temp Change Simulator",
        "func": "let payload = {};\n\n// Loop through Zone 1 to Zone 9 to generate random simulated sensor values\nfor (let i = 1; i <= 9; i++) {\n    let temp = Math.floor(Math.random() * 15) + 20;     // Temperature: 20~35°C\n    let moisture = Math.floor(Math.random() * 40) + 10; // Soil Moisture: 10~50%\n    let nutrient = Math.floor(Math.random() * 10);      // Soil Nutrients: 0~9 (Probability simulator)\n\n    let color = \"#0099cc\"; // Default state: Normal (Deep Blue)\n    let displayValue = \"OK\";\n\n    // 🚨 Logic Rule (Priority: High Temp > Low Moisture > Low Nutrients)\n    if (temp >= 30) {\n        color = \"red\"; // High Temperature alert\n        displayValue = temp + \"°C\";\n    } else if (moisture <= 20) {\n        color = \"#ccffff\"; // Low Soil Moisture alert (Light Blue)\n        displayValue = moisture + \"% 💧\";\n    } else if (nutrient === 0) {\n        color = \"#33cc33\"; // Low Soil Nutrients alert (Green)\n        displayValue = \"Low N\";\n    }\n\n    // Store the color(c) and display value(v) in the payload object\n    payload[\"c\" + i] = color;\n    payload[\"v\" + i] = displayValue;\n}\n\nmsg.payload = payload;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
